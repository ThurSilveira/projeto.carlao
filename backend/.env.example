# ==========================================
# BACKEND - CONFIGURAÇÃO DE AMBIENTE
# ==========================================
# Copie este arquivo para .env e preencha os valores apropriados
# cp .env.example .env

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_PORT=8080

# ==========================================
# DATABASE - PostgreSQL
# ==========================================
# DESENVOLVIMENTO: localhost com sem senha
# PRODUÇÃO (Render): Use a conexão fornecida pelo Render

DB_HOST=localhost
DB_PORT=5432
DB_NAME=escala_ministerial
DB_USERNAME=arthursilveira
DB_PASSWORD=

# ==========================================
# JPA / HIBERNATE
# ==========================================
# validate: apenas valida o schema
# update: atualiza schema conforme entities
# create: cria novo schema (cuidado!)
# create-drop: cria e deleta ao desligar
JPA_HIBERNATE_DDL_AUTO=validate
JPA_SHOW_SQL=false

# ==========================================
# SECURITY - JWT
# ==========================================
# Mínimo 32 caracteres para produção!
# Use: openssl rand -base64 32
JWT_SECRET=sua_chave_super_secreta_minimo_32_caracteres_para_producao_2024_aqui
JWT_EXPIRATION=86400

# ==========================================
# LOGGING
# ==========================================
# Levels: TRACE, DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL=INFO

# ==========================================
# TIMEZONE
# ==========================================
TIMEZONE=America/Sao_Paulo

# ==========================================
# CORS - Frontend URL
# ==========================================
# Desenvolvimento
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Produção (Render)
# CORS_ORIGINS=https://seu-frontend.onrender.com
